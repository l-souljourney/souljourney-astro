{
  "name": "l-souljourney-blog",
  "type": "module",
  "version": "2.3.4",
  "description": "L-忠程的个人博客，记录投资感悟、AI探索、商业思考与人生哲学",
  "author": "执笔忠程",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "node --import tsx --test tests/*.mjs tests/*.ts",
    "verify:baseline": "pnpm check && pnpm test && pnpm build && pnpm check:publish-health",
    "newpost": "node ./script/newpost.js",
    "check:publish-health": "node ./script/publish-health.js",
    "check:publish-bilingual-readiness": "MAX_PENDING_TRANSLATIONS=0 node ./script/publish-health.js",
    "purge:edgeone": "node ./script/edgeone-purge.js",
    "offdev": "astro preferences disable devToolbar",
    "ondev": "astro preferences enable devToolbar"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@pagefind/default-ui": "^1.4.0",
    "astro": "^6.2.1",
    "astro-icon": "^1.1.5",
    "medium-zoom": "^1.1.0",
    "overlayscrollbars": "^2.11.2",
    "pagefind": "^1.4.0",
    "sirv": "^3.0.0",
    "vanilla-lazyload": "^19.1.3",
    "vh-plugin": "^1.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playform/compress": "^0.1.9",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.22",
    "cheerio": "^1.0.0",
    "dayjs": "^1.11.13",
    "devalue": "^5.7.0",
    "less": "^4.3.0",
    "mdast-util-to-string": "^4.0.0",
    "postcss": "^8.5.6",
    "reading-time": "^1.5.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-sectionize": "^2.1.0",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "unist-util-visit": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "swup"
    ]
  }
